# 複製本檔為 .dev.vars（本機 Workers dev 讀取），填入實際值。
# .dev.vars 與 .env 一律加入 .gitignore，切勿提交。
# 正式環境改用：wrangler secret put <NAME>

# ── Better Auth ───────────────────────────────
# 產生方式：openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# ── Google OAuth ──────────────────────────────
# Google Cloud Console → OAuth 用戶端；
# 授權重新導向 URI：http://localhost:5173/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── （選用）drizzle-kit studio 連遠端 D1 ─────────
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_DATABASE_ID=
# CLOUDFLARE_D1_TOKEN=

# 註：D1 / R2 / KV 綁定在 wrangler.jsonc 設定，不放這裡。
