{
  "name": "khubs",
  "version": "1.0.0",
  "type": "module",
  "description": "高創坊 - 高雄創新創業社群商會系統",
  "main": "index.js",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler pages dev .svelte-kit/cloudflare",
    "deploy": "npm run build && wrangler pages deploy .svelte-kit/cloudflare --project-name=khubs",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply chamber-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply chamber-db --remote",
    "db:seed:remote": "wrangler d1 execute chamber-db --remote --file=./scripts/seed.sql",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260627.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.56.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wrangler": "^4.105.0"
  },
  "dependencies": {
    "better-auth": "^1.2.8",
    "drizzle-orm": "^0.45.2"
  },
  "homepage": "https://khubs.net"
}
